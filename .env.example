# Hafeez Communication — environment variables
# Copy to `.env` and fill in. (Ahmed provides DATABASE_URL from his own Neon project.)

# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js session secret — any long random string. Generate: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"

# Single admin credential (there is no user table)
ADMIN_EMAIL="owner@example.com"

# Bootstrap credential for the FIRST login only. After the first successful
# login this is copied into the AdminUser table, and the password can then be
# changed from /admin/settings (env is ignored thereafter).
#
# Generate: node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'your-password'
#
# IMPORTANT: a bcrypt hash contains `$`, which Next.js expands as a variable in
# .env files. Escape EACH `$` as `\$` here, e.g. \$2b\$10\$....
# (On Vercel's env UI paste the RAW hash — no escaping there.)
ADMIN_PASSWORD_HASH=""

# Dev-only fallback if ADMIN_PASSWORD_HASH is empty (plaintext — do not use in prod)
# ADMIN_PASSWORD="changeme"
